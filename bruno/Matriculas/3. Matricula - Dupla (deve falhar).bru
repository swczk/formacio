meta {
  name: 3. Matricula - Dupla (deve falhar)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/matriculas
  body: json
  auth: none
}

body:json {
  {
    "interessadoId": "{{novoInteressadoId}}"
  }
}

docs {
  Tenta criar uma segunda matrícula para o mesmo interessado.
  Deve retornar 422 com erro "Interessado já possui matrícula activa."
  Requer que o teste 2 tenha sido executado primeiro.
}
